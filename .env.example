# === EMAIL KONFIGURÁCIÓ ===
# A rendszer automatikusan választ a beállított szolgáltatók közül:
#   1. SMTP (elsődleges) – ha SMTP_HOST, SMTP_USER, SMTP_PASSWORD be van állítva
#   2. Resend (másodlagos) – ha RESEND_API_KEY be van állítva
#   3. Mock (fejlesztői mód) – ha egyik sincs konfigurálva

# --- SMTP (ajánlott fejlesztéshez, pl. Gmail alkalmazásjelszóval) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Parisi 6 <myemail@gmail.com>"

# --- Resend (production, ha van verified domain) ---
# Get yours at https://resend.com
# Csak akkor használatos, ha SMTP nincs konfigurálva.
RESEND_API_KEY=

# --- Címzett (tulajdonos e-mail) ---
# Erre a címre érkeznek az új foglalási értesítők.
# Kötelező production módban.
RESERVATION_EMAIL=

# === EGYÉB ===
# Public site URL (Vercel deployment URL vagy egyedi domain)
# SEO metaadatokhoz, OpenGraph képekhez, sitemap-hez használva
NEXT_PUBLIC_SITE_URL=http://localhost:3000
