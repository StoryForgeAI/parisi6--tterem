# Resend API key for sending reservation confirmation emails
# Get yours at https://resend.com
# Required for production. Without it, reservations work in mock mode.
RESEND_API_KEY=

# Email address where reservation notifications are sent
# Required for production. Without it, reservations work in mock mode.
RESERVATION_EMAIL=

# Public site URL (set to your Vercel deployment URL or custom domain)
# Used for SEO metadata, OpenGraph images, and sitemap
NEXT_PUBLIC_SITE_URL=http://localhost:3000
